# Environment Variables Example
# Format: VARIABLE_NAME= # [Type] | [Required/Optional] | [Description]

ENVIRONMENT= # string | Optional | Application environment (dev or prod). Default: dev.
DELAY= # int | Optional | Simulated delay for responses in milliseconds.
ORIGINS= # string | Optional | Allowed CORS origins (comma-separated URLs).
GCP_PROJECT_ID= # string | Optional | Google Cloud Project ID.
PORT= # int | Optional | Port for the HTTP server. Default: 8080.

DATABASE_URL= # string | Required | PostgreSQL connection string.
GOOGLE_CLIENT_ID= # string | Required | Google OAuth2 Client ID.
GOOGLE_CLIENT_SECRET= # string | Required | Google OAuth2 Client Secret.
LOGIN_REDIRECT_URI= # string | Required | URI to redirect after Google login.
JWT_SECRET= # string | Required | Secret key for signing JWT tokens.


# Sized rate limits (Optional)
# If not provided, the application will use the hardcoded defaults.

RATE_LIMIT_XS_MAX_REQUESTS= # int | Optional | Default: 10
RATE_LIMIT_XS_WINDOW_MS=    # int | Optional | Default: 60000
RATE_LIMIT_SM_MAX_REQUESTS= # int | Optional | Default: 30
RATE_LIMIT_SM_WINDOW_MS=    # int | Optional | Default: 60000
RATE_LIMIT_MD_MAX_REQUESTS= # int | Optional | Default: 60
RATE_LIMIT_MD_WINDOW_MS=    # int | Optional | Default: 60000
RATE_LIMIT_LG_MAX_REQUESTS= # int | Optional | Default: 120
RATE_LIMIT_LG_WINDOW_MS=    # int | Optional | Default: 60000
RATE_LIMIT_XL_MAX_REQUESTS= # int | Optional | Default: 240
RATE_LIMIT_XL_WINDOW_MS=    # int | Optional | Default: 60000